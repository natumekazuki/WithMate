{
  "name": "withmate",
  "version": "1.0.0",
  "description": "Codex SDK spike for WithMate",
  "private": true,
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "codex:file-op": "tsx scripts/codex-sdk-file-op-test.ts",
    "codex:smoke": "tsx scripts/codex-sdk-smoke-test.ts",
    "dev": "vite",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "electron:dev": "npm run build:electron && tsx scripts/run-electron-dev.ts",
    "electron:start": "npm run build && electron dist-electron/src-electron/main.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@openai/codex-sdk": "^0.114.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^41.0.0",
    "vite": "^7.3.1"
  }
}
