+function readAuditLogCountRows(db: DatabaseSync): Map<string, number> {
+  const rows = db.prepare(LIST_SESSION_AUDIT_LOG_COUNTS_SQL).all() as SessionAuditLogCountRow[];
+  const map = new Map<string, number>();
+
+  for (const row of rows) {
+    map.set(row.id, row.audit_log_count);
+  }
+
+  return map;
+}
+
+function upsertSessionMessages(
+  insertMessage: ReturnType<DatabaseSync["prepare"]>,
+  insertArtifact: ReturnType<DatabaseSync["prepare"]>,
+  session: Session,
+): void {
+  for (let index = 0; index < session.messages.length; index += 1) {
+    const message = session.messages[index];
+    const messageResult = insertMessage.run(
+      session.id,
+      index,
+      message.role,
+      message.text,
+      message.accent === true ? 1 : 0,
+      message.artifact ? 1 : 0,
+      "",
+    );
+    if (message.artifact) {
+      const messageId = Number(messageResult.lastInsertRowid);
+      insertArtifact.run(messageId, JSON.stringify(message.artifact));
+    }
+  }
+}
